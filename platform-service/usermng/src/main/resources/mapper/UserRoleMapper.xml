<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pg.platform.usermng.domain.mapper.UserRoleMapper">

    <resultMap id="BaseResultMap" type="com.pg.platform.usermng.domain.model.UserRoleEntity">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role_id" property="roleId"/>
        <result column="create_time" property="createTime"/>
        <result column="create_by" property="createBy"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, role_id, create_time, create_by
    </sql>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_role_tbl WHERE user_id = #{userId}
    </select>

    <delete id="deleteByUserId">
        DELETE FROM user_role_tbl WHERE user_id = #{userId}
    </delete>

    <delete id="deleteByRoleId">
        DELETE FROM user_role_tbl WHERE role_id = #{roleId}
    </delete>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_role_tbl (user_id, role_id, create_by)
        VALUES (#{userId}, #{roleId}, #{createBy})
    </insert>

    <select id="countByUserIdAndRoleId" resultType="int">
        SELECT COUNT(*) FROM user_role_tbl WHERE user_id = #{userId} AND role_id = #{roleId}
    </select>
</mapper>
